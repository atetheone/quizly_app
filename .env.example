# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/quizly

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Set to your production URL (e.g. https://quizly.vercel.app)
# On Vercel this can be omitted — VERCEL_URL is used automatically
NEXTAUTH_URL=

# Required on Vercel / any reverse-proxy deployment
AUTH_TRUST_HOST=true

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Pusher ──────────────────────────────────────────────────────────────────
# Create an app at https://pusher.com/
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Exposed to the browser — must match the server-side values above
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# ─── AI quiz generation ──────────────────────────────────────────────────────
# Free key from https://openrouter.ai/ (Keys → create key). No card required
# for :free model variants. Used server-side for topic+difficulty generation.
OPENROUTER_API_KEY=
# Optional model override. Defaults to a strong free model; swap without a
# deploy if a free model is rate-limited or deprecated.
QUIZ_GEN_MODEL=meta-llama/llama-3.3-70b-instruct:free
